set $cyan               #00b5bd

set_from_resource $fg m3onSurfaceVariant
set_from_resource $bg m3outlineVariant
set_from_resource $ac m3primary
set_from_resource $bac m3onPrimaryFixed

# class                 border  backgr. text indicator child_border
client.focused          $ac     $ac     $bac $ac       $ac
client.focused_inactive $bg     $bg     $fg  $bg       $bg
